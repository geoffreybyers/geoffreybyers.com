---
import Layout from "../../layouts/Layout.astro";
import PostRow from "../../components/PostRow.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("posts", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---
<Layout title="Posts" description="All writing — notes on projects, companies, and building in public.">
  <h1 class="text-[2.5rem] leading-[1.1] font-semibold tracking-tight">Posts</h1>
  {posts.length === 0 ? (
    <p class="mt-8 text-[var(--fg-muted)]">No posts yet.</p>
  ) : (
    <ul class="mt-10 border-t border-[var(--rule)]">
      {posts.map((post) => (
        <PostRow post={post} />
      ))}
    </ul>
  )}
</Layout>
