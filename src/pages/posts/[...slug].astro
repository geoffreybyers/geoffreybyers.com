---
import Layout from "../../layouts/Layout.astro";
import { getCollection, getEntry, render } from "astro:content";
import { formatDate } from "../../lib/formatDate";

export async function getStaticPaths() {
  const posts = await getCollection("posts", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

let workEntry: Awaited<ReturnType<typeof getEntry>> | undefined;
if (post.data.work) {
  workEntry = await getEntry(post.data.work);
  if (!workEntry) {
    throw new Error(`Post "${post.data.title}" references missing work entry "${post.data.work.id}".`);
  }
  if (workEntry.data.type !== "case-study") {
    throw new Error(
      `Post "${post.data.title}" references work "${workEntry.id}" with type "${workEntry.data.type}" — only case-study entries are linkable from posts.`
    );
  }
}
---
<Layout title={post.data.title} description={post.data.description}>
  <nav class="flex flex-wrap items-center gap-3 text-[0.8125rem] font-mono text-[var(--fg-muted)]">
    <a href="/posts" class="underline-grow">← Posts</a>
    {workEntry && (
      <>
        <span aria-hidden="true" class="text-[var(--fg-subtle)]">·</span>
        <span>
          Part of {" "}
          <a href={`/work/${workEntry.id}`} class="underline-grow text-[var(--fg)]">
            {workEntry.data.name}
          </a>
        </span>
      </>
    )}
  </nav>

  <header class="mt-6">
    <h1 class="text-[2.5rem] leading-[1.1] font-semibold tracking-tight">{post.data.title}</h1>
    <time
      datetime={post.data.pubDate.toISOString()}
      class="mt-3 block font-mono text-[0.8125rem] text-[var(--fg-muted)]"
    >
      {formatDate(post.data.pubDate)}
    </time>
  </header>

  <article class="prose prose-lg dark:prose-invert max-w-none mt-10">
    <Content />
  </article>

  <hr class="mt-16 border-0 border-t border-[var(--rule)]" />

  <div class="mt-8 flex flex-wrap items-center justify-between gap-4 text-[0.8125rem] font-mono text-[var(--fg-muted)]">
    {post.data.tags.length > 0 ? (
      <span class="flex flex-wrap gap-2">
        Tags: {post.data.tags.map((tag, i) => (
          <>
            {i > 0 && <span aria-hidden="true" class="text-[var(--fg-subtle)]">·</span>}
            <span>{tag}</span>
          </>
        ))}
      </span>
    ) : (
      <span />
    )}
    <span class="flex items-center gap-3">
      <a href="/posts" class="underline-grow">← All posts</a>
      <span aria-hidden="true" class="text-[var(--fg-subtle)]">·</span>
      <a href="/rss.xml" class="underline-grow">RSS</a>
    </span>
  </div>
</Layout>
