---
import Layout from "../layouts/Layout.astro";
import { SITE, SOCIAL_LINKS } from "../lib/constants";
---
<Layout title="About" description="About Geoffrey Byers.">
  <h1 class="text-[2.5rem] leading-[1.1] font-semibold tracking-tight">About</h1>

  <article class="prose prose-lg dark:prose-invert max-w-none mt-10">
    <p>
      I'm a value-obsessed builder based in Dallas, TX. I speak fluent business, design, and engineering - translating between them to ship faster with fewer mistakes. Strategic thinker, ruthless prioritizer, methodical doer. Founder on the card, designer in the mind, customer at heart.
    </p>
    <p>
      My core beliefs include demystifying the unknown, radical transparency, and iterating towards perfection. 
    </p>
    <p>
      I prefer long-form stories to short, lean to bloated, and shipping over talking about shipping.
    </p>
  </article>

  <section class="mt-14">
    <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
      Contact
    </h2>
    <ul class="mt-4 space-y-2 text-[1.0625rem]">
      <li>
        <a href={`mailto:${SITE.email}`} class="underline-grow text-[var(--fg)]">
          {SITE.email}
        </a>
      </li>
      {SOCIAL_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            rel="me noopener"
            target="_blank"
            class="group underline-grow text-[var(--fg)]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
