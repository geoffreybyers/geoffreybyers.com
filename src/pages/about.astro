---
import Layout from "../layouts/Layout.astro";
import { SITE, SOCIAL_LINKS } from "../lib/constants";
---
<Layout title="About" description="About Geoffrey Byers.">
  <h1 class="text-[2.5rem] leading-[1.1] font-semibold tracking-tight">About</h1>

  <article class="prose prose-lg dark:prose-invert max-w-none mt-10">
    <p>
      I'm Geoffrey, based in Dallas, TX. My background is a loop of
      design, product, and engineering — I've built and sold a DTC
      brand, shipped a handful of tools, and spend most of my time
      now running a B2B cold-email service for local restaurants.
    </p>
    <p>
      I write here about the things I'm actively building and the
      ones I've put down. Every project gets a case-study page;
      writing about it threads into that page so the story stays
      linked. Small things link out to their GitHub repos.
    </p>
    <p>
      I prefer long-form to threads, dictation to typing, and
      shipping over polishing.
    </p>
  </article>

  <section class="mt-14">
    <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
      Currently —
    </h2>
    <ul class="mt-4 space-y-2 text-[1.0625rem] text-[var(--fg)]">
      <li class="flex gap-3">
        <span aria-hidden="true" class="text-[var(--fg-subtle)]">•</span>
        <span>Building a B2B cold-email service for Dallas restaurants</span>
      </li>
      <li class="flex gap-3">
        <span aria-hidden="true" class="text-[var(--fg-subtle)]">•</span>
        <span>Shipping a dictation-to-blog pipeline for myself</span>
      </li>
      <li class="flex gap-3">
        <span aria-hidden="true" class="text-[var(--fg-subtle)]">•</span>
        <span>Thinking about what "building in public" actually buys you</span>
      </li>
    </ul>
  </section>

  <section class="mt-14">
    <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
      Contact
    </h2>
    <ul class="mt-4 space-y-2 text-[1.0625rem]">
      <li>
        <a href={`mailto:${SITE.email}`} class="underline-grow text-[var(--fg)]">
          {SITE.email}
        </a>
      </li>
      {SOCIAL_LINKS.map((link) => (
        <li>
          <a
            href={link.href}
            rel="me noopener"
            target="_blank"
            class="group underline-grow text-[var(--fg)]"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>
