---
import Layout from "../layouts/Layout.astro";
import Search from "../components/Search.tsx";
---
<Layout title="Search" description="Search posts and work.">
  <h1 class="text-[2.5rem] leading-[1.1] font-semibold tracking-tight">Search</h1>
  <p class="mt-3 text-[var(--fg-muted)]">Type two or more characters.</p>
  <div class="mt-8">
    <Search client:load />
  </div>
</Layout>
