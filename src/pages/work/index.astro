---
import { getCollection } from "astro:content";
import WorkRow from "../../components/WorkRow.astro";
import Layout from "../../layouts/Layout.astro";
import { sortWork } from "../../lib/sortWork";

const all = await getCollection("work");
const companies = sortWork(all.filter((w) => w.data.kind === "company"));
const projects = sortWork(all.filter((w) => w.data.kind === "project"));
---
<Layout title="Work" description="Companies and projects — past, maintained, and in progress.">
  <h1 class="text-[2.5rem] leading-[1.1] font-semibold tracking-tight">Work</h1>

  {companies.length > 0 && (
    <section class="mt-14">
      <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
        Companies
      </h2>
      <ul class="mt-4 border-t border-[var(--rule)]">
        {companies.map((entry, i) => (
          <WorkRow entry={entry} index={i + 1} />
        ))}
      </ul>
    </section>
  )}

  {projects.length > 0 && (
    <section class="mt-14">
      <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
        Projects
      </h2>
      <ul class="mt-4 border-t border-[var(--rule)]">
        {projects.map((entry, i) => (
          <WorkRow entry={entry} index={i + 1} />
        ))}
      </ul>
    </section>
  )}

  {companies.length === 0 && projects.length === 0 && (
    <p class="mt-10 text-[var(--fg-muted)]">Nothing here yet.</p>
  )}
</Layout>
