---
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import headshot from "../assets/headshot.jpg";
import PostRow from "../components/PostRow.astro";
import WorkRow from "../components/WorkRow.astro";
import Layout from "../layouts/Layout.astro";

const allWork = await getCollection("work");
const featuredWork = allWork
  .filter((w) => w.data.featured)
  .sort((a, b) => b.data.startDate.getTime() - a.data.startDate.getTime())
  .slice(0, 3);

const recentPosts = (await getCollection("posts", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);
---
<Layout>
  <section class="py-4 sm:py-10 flex flex-col sm:flex-row sm:items-stretch gap-6 sm:gap-8">
    <div class="shrink-0 w-40 aspect-square sm:w-auto sm:h-auto sm:self-stretch rounded-full overflow-hidden bg-[var(--bg-subtle)]">
      <Image
        src={headshot}
        alt="Geoffrey Byers"
        widths={[240, 400, 600]}
        sizes="(min-width: 640px) 18rem, 10rem"
        class="h-full w-full object-cover"
      />
    </div>
    <div class="min-w-0">
      <h1 class="text-[3.5rem] leading-[1.05] font-semibold tracking-tight">
        Howdy, I'm Geoffrey
      </h1>
      <h2 class="mt-6 text-[1.75rem] leading-[1.25] font-normal tracking-tight text-[var(--fg-muted)] max-w-[40rem]">
        Designer turned solopreneur, content creator, and ai-first builder.
      </h2>
    </div>
  </section>

  {featuredWork.length > 0 && (
    <section class="mt-16">
      <div class="flex items-baseline justify-between">
        <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
          Current work
        </h2>
        <a href="/work" class="group underline-grow font-mono text-[0.8125rem] text-[var(--fg-muted)]">
          All work <span aria-hidden="true">→</span>
        </a>
      </div>
      <ul class="mt-4 border-t border-[var(--rule)]">
        {featuredWork.map((entry, i) => (
          <WorkRow entry={entry} index={i + 1} />
        ))}
      </ul>
    </section>
  )}

  {recentPosts.length > 0 && (
    <section class="mt-16">
      <div class="flex items-baseline justify-between">
        <h2 class="font-mono text-[0.8125rem] font-medium uppercase tracking-[0.1em] text-[var(--fg-muted)]">
          Latest posts
        </h2>
        <a href="/posts" class="group underline-grow font-mono text-[0.8125rem] text-[var(--fg-muted)]">
          All posts <span aria-hidden="true">→</span>
        </a>
      </div>
      <ul class="mt-4 border-t border-[var(--rule)]">
        {recentPosts.map((post) => (
          <PostRow post={post} />
        ))}
      </ul>
    </section>
  )}
</Layout>
