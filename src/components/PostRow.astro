---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../lib/formatDate";

interface Props {
  post: CollectionEntry<"posts">;
  compact?: boolean;
}

const { post, compact = false } = Astro.props;
---
<li class="border-b border-[var(--rule)] last:border-b-0">
  <a
    href={`/posts/${post.id}`}
    class="group grid grid-cols-[1fr_auto] items-baseline gap-4 py-5"
  >
    <span class="min-w-0">
      <span class="block text-[1.0625rem] font-medium text-[var(--fg)] underline-grow">
        {post.data.title}
      </span>
      {!compact && post.data.description && (
        <span class="mt-1 block text-[0.875rem] text-[var(--fg-muted)]">
          {post.data.description}
        </span>
      )}
    </span>
    <time
      datetime={post.data.pubDate.toISOString()}
      class="whitespace-nowrap font-mono text-[0.8125rem] text-[var(--fg-muted)] tabular-nums"
    >
      {formatDate(post.data.pubDate)}
    </time>
  </a>
</li>
